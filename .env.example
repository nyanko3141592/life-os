# Life OS — 環境変数テンプレート
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env は .gitignore に含まれているため、機密情報はコミットされません。

# ===========================
# Zaim API（オプション）
# https://dev.zaim.net/ でアプリを作成して取得
# ===========================
ZAIM_CONSUMER_KEY=your_consumer_key_here
ZAIM_CONSUMER_SECRET=your_consumer_secret_here
